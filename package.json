{
  "name": "transparent-ref-viewer",
  "version": "1.3.0",
  "author": "anshaer",
  "description": "半透明置頂參考圖工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.anshaer.refviewer",
    "productName": "AuxiliaryReferenceImage", 
    "mac": {
      "target": "dmg",
      "identity": null,
      "icon": "icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
